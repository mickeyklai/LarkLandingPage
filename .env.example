# --- Run for real (once this file is copied and filled) ---
# 1) cp .env.example .env.local
# 2) Fill every blank value below (at minimum: SANITY_API_WRITE_TOKEN, GROQ_API_KEY,
#    and one image source: HF_TOKEN and/or BLOG_IMAGE_POOL_REFS).
# 3) In the repo root: npm install   (first time only)
# 4) npm run publish:daily-blog
#    Success: logs "Created post: …" and you see the new post in Sanity Studio + on /blog/
#    Same calendar day + same topic: slug already exists → script exits quietly (idempotent).
#    Extra post same day: BLOG_MULTIPLE_PER_DAY=1 or: npm run publish:daily-blog -- --next-slug
# Dry run (no writes): npm run publish:daily-blog -- --dry-run
#
# Copy to .env.local (recommended) or .env — both are gitignored.
#
# Sanity project id + dataset (public — same as studio/sanity.config.js)
SANITY_PROJECT_ID=cb72ulln
SANITY_DATASET=production
#
# Create a WRITE token: https://www.sanity.io/manage → your project → API → Tokens
# Use role "Editor" (or custom with create on `post` + upload assets).
SANITY_API_WRITE_TOKEN=
#
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_JSON_MODE=0   # only if Groq errors on json_object response_format for your model
#
# Images (script uses first available: HF → pool). HF prompts here are Lark-only:
# HF prompts: coherent people with natural faces + correct hands; dark-romance mood + Pinterest-friendly composition.
# https://huggingface.co/settings/tokens — enable Inference / read for Inference Providers.
HF_TOKEN=
# Optional HF tuning (defaults shown in comments):
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_IMAGE_PROVIDER=auto
# HF_IMAGE_WIDTH=1216
# HF_IMAGE_HEIGHT=832
# HF_NUM_INFERENCE_STEPS=5
#
# Or comma-separated Sanity image asset _ids (Studio uploads), if HF_TOKEN unset:
# BLOG_IMAGE_POOL_REFS=image-xxxxx,image-yyyyy
#
# Site + newsletter CTA in every generated post (Groq uses these in the closing paragraph):
BLOG_PUBLIC_URL=https://larkelwood.com
# Optional: full URL if different from BLOG_PUBLIC_URL + /#reader-list
# BLOG_READER_LIST_URL=https://larkelwood.com/#reader-list
#
# Clickable CTA appended to every post (Portable Text link — not plain URL text):
# BLOG_NEWSLETTER_LINK_TEXT=Join the reader list
# BLOG_CTA_LINE_BEFORE=If you want the rest in your inbox—release crumbs, desk confessions, and what simmers behind 
# BLOG_CTA_LINE_AFTER=on the homepage.
#
# Main-image webhook rotation: default total states is 10 (hero 1 at create, then 9 patches).
# BLOG_MAINIMAGE_WEBHOOK_DELAY_MS=10000
# BLOG_MAINIMAGE_PIN_PATCH_COUNT=10
# BLOG_MAINIMAGE_PIN_PATCHES=   # set to 0 to disable extra mainImage patches
